let activeFilter = 'all';
let searchTerm = '';
let filtered = [];

// KPIs
document.getElementById('k-total').textContent = DATA.length;
document.getElementById('k-tel').textContent   = DATA.filter(r=>r.sem_tel).length;
document.getElementById('k-data').textContent  = DATA.filter(r=>r.status_data==='sem_data').length;
document.getElementById('k-err').textContent   = DATA.filter(r=>r.status_data==='data_errada').length;
document.getElementById('k-proc').textContent  = DATA.filter(r=>r.tem_proc).length;
document.getElementById('k-new').textContent   = DATA.filter(r=>!r.tem_proc).length;

function fmtBRL(v){
  if(!v) return '—';
  return 'R$\u00a0'+v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
}

function setFilter(f){
  activeFilter = f;
  document.querySelectorAll('.filter-pill').forEach(p=>{
    p.classList.toggle('active', p.dataset.f === f);
  });
  apply();
}

function apply(){
  let r = DATA;
  if(activeFilter === 'sem_tel')     r = r.filter(x=>x.sem_tel);
  if(activeFilter === 'sem_data')    r = r.filter(x=>x.status_data==='sem_data');
  if(activeFilter === 'data_errada') r = r.filter(x=>x.status_data==='data_errada');
  if(activeFilter === 'tem_proc')    r = r.filter(x=>x.tem_proc);
  if(activeFilter === 'nunca_proc')  r = r.filter(x=>!x.tem_proc);

  if(searchTerm){
    const t = searchTerm.toLowerCase();
    r = r.filter(x => x.nome.toLowerCase().includes(t) || x.telefone.includes(t));
  }

  filtered = r;
  document.getElementById('result-info').textContent = r.length + ' cadastros';
  render();
}

function render(){
  const tbody = document.getElementById('tbody');
  const empty = document.getElementById('empty');
  if(!filtered.length){ tbody.innerHTML=''; empty.style.display='block'; return; }
  empty.style.display='none';

  tbody.innerHTML = filtered.map(r => {
    const tags = [];
    if(r.sem_tel)                          tags.push('<span class="tag sem-tel">Sem telefone</span>');
    if(r.status_data === 'sem_data')       tags.push('<span class="tag sem-data">Sem data nasc.</span>');
    if(r.status_data === 'data_errada')    tags.push('<span class="tag data-err">Data errada</span>');
    if(r.tem_proc)                         tags.push('<span class="tag tem-proc">Com procedimento</span>');
    if(!r.tem_proc)                        tags.push('<span class="tag nunca-proc">Nunca realizou</span>');

    const tel = r.telefone
      ? r.telefone
      : '<span style="color:var(--red);font-size:10px">—</span>';

    const nasc = r.nascimento || '<span style="color:var(--amber);font-size:10px">—</span>';
    const idade = r.idade || '<span style="color:var(--white-faint);font-size:10px">—</span>';
    const ult = r.ultima_visita || '<span style="color:var(--white-faint);font-size:10px">—</span>';
    const gasto = r.total_gasto ? fmtBRL(r.total_gasto) : '<span style="color:var(--white-faint);font-size:10px">—</span>';

    return `<tr>
      <td class="name">${r.nome}</td>
      <td class="tel">${tel}</td>
      <td style="font-size:11px">${nasc}</td>
      <td style="font-size:11px">${idade}</td>
      <td style="font-size:11px;color:var(--white-faint)">${ult}</td>
      <td style="font-family:'Cormorant Garamond',serif;font-size:15px;color:var(--gold-light)">${gasto}</td>
      <td>${tags.join('')}</td>
    </tr>`;
  }).join('');
}

document.querySelectorAll('.filter-pill').forEach(p=>{
  p.addEventListener('click', ()=>setFilter(p.dataset.f));
});
document.getElementById('search').addEventListener('input', e=>{
  searchTerm = e.target.value.trim();
  apply();
});

apply();
