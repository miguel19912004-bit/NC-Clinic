<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NC Clinic · Correção de Cadastros</title>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@100;200;300;400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#bca366;--gold-dim:#8a7548;--gold-faint:rgba(188,163,102,0.07);
  --black:#0a0a0a;--card:#141414;--card2:#1b1b1b;
  --border:#222;--border2:#2d2d2d;
  --white:#f0ece4;--white-dim:#9a9286;--white-faint:#5a5248;
  --red:#b04040;--red-faint:rgba(176,64,64,0.08);
  --amber:#c8903a;--amber-faint:rgba(200,144,58,0.08);
  --green:#5a9e6a;--green-faint:rgba(90,158,106,0.08);
  --blue:#5a82b0;--blue-faint:rgba(90,130,176,0.08);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--black);color:var(--white);font-family:'Archivo',sans-serif;font-weight:200;min-height:100vh;-webkit-font-smoothing:antialiased;}

.nav{display:flex;align-items:center;border-bottom:1px solid var(--border);background:rgba(10,10,10,0.97);position:sticky;top:0;z-index:100;backdrop-filter:blur(12px);gap:0;flex-wrap:wrap;}
.logo{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:20px;letter-spacing:0.2em;color:var(--gold);padding:14px 22px;border-right:1px solid var(--border);white-space:nowrap;}
.nav-right{display:flex;align-items:center;gap:8px;padding:8px 18px;flex-wrap:wrap;flex:1;}
.filter-pill{
  padding:6px 14px;border:1px solid var(--border2);background:transparent;
  color:var(--white-dim);font-family:'Archivo',sans-serif;font-size:10px;font-weight:200;
  letter-spacing:0.08em;cursor:pointer;transition:all .18s;white-space:nowrap;
}
.filter-pill:hover{border-color:var(--white-faint);color:var(--white);}
.filter-pill.active{color:var(--black) !important;font-weight:400;}
.filter-pill[data-f="all"].active         {background:var(--gold);border-color:var(--gold);color:var(--black);}
.filter-pill[data-f="sem_tel"].active     {background:var(--red);border-color:var(--red);}
.filter-pill[data-f="sem_data"].active    {background:var(--amber);border-color:var(--amber);}
.filter-pill[data-f="data_errada"].active {background:#7a5090;border-color:#7a5090;}
.filter-pill[data-f="tem_proc"].active    {background:var(--green);border-color:var(--green);}
.filter-pill[data-f="nunca_proc"].active  {background:var(--blue);border-color:var(--blue);}
.result-info{font-size:11px;color:var(--white-faint);letter-spacing:0.05em;margin-left:auto;white-space:nowrap;}

.search-bar{padding:10px 22px;border-bottom:1px solid var(--border);background:var(--card);display:flex;gap:10px;align-items:center;}
.search-wrap{position:relative;flex:1;max-width:400px;}
.search-wrap svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);opacity:0.3;pointer-events:none;}
input[type=text]{width:100%;background:var(--black);border:1px solid var(--border2);color:var(--white);font-family:'Archivo',sans-serif;font-weight:200;font-size:13px;padding:8px 12px 8px 32px;outline:none;transition:border-color .2s;}
input[type=text]:focus{border-color:var(--gold-dim);}
input[type=text]::placeholder{color:var(--white-faint);}

/* KPI STRIP */
.kpi-strip{display:flex;gap:1px;background:var(--border);border-bottom:1px solid var(--border);}
.kpi{background:var(--card);padding:14px 20px;flex:1;min-width:0;cursor:pointer;transition:background .15s;}
.kpi:hover{background:var(--card2);}
.kpi-val{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;line-height:1;}
.kpi-label{font-size:8px;letter-spacing:0.28em;text-transform:uppercase;color:var(--white-faint);margin-top:3px;}
.kpi.k-total .kpi-val   {color:var(--gold);}
.kpi.k-tel .kpi-val     {color:var(--red);}
.kpi.k-data .kpi-val    {color:var(--amber);}
.kpi.k-err .kpi-val     {color:#9a60c0;}
.kpi.k-proc .kpi-val    {color:var(--green);}
.kpi.k-new .kpi-val     {color:var(--blue);}

/* TABLE */
.table-wrap{overflow-x:auto;padding:0 22px 80px;}
table{width:100%;border-collapse:collapse;min-width:680px;}
thead th{font-size:8px;letter-spacing:0.3em;text-transform:uppercase;color:var(--white-faint);font-weight:400;padding:12px 10px 8px;border-bottom:1px solid var(--border2);text-align:left;cursor:pointer;user-select:none;white-space:nowrap;}
thead th:hover{color:var(--gold);}
tbody tr{border-bottom:1px solid var(--border);transition:background .1s;}
tbody tr:hover{background:rgba(255,255,255,0.02);}
td{padding:11px 10px;font-size:12px;color:var(--white-dim);vertical-align:middle;}
td.name{font-family:'Cormorant Garamond',serif;font-size:15px;color:var(--white);letter-spacing:0.02em;}
td.tel{font-size:11px;letter-spacing:0.03em;}

.tag{display:inline-block;font-size:8px;letter-spacing:0.1em;padding:2px 7px;border:1px solid;margin:1px;}
.tag.sem-tel    {border-color:var(--red);color:var(--red);}
.tag.sem-data   {border-color:var(--amber);color:var(--amber);}
.tag.data-err   {border-color:#9a60c0;color:#9a60c0;}
.tag.tem-proc   {border-color:var(--green);color:var(--green);}
.tag.nunca-proc {border-color:var(--blue);color:var(--blue);}
.tag.ok         {border-color:var(--border2);color:var(--white-faint);}

.empty{text-align:center;padding:80px 22px;font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--white-faint);font-style:italic;}

::-webkit-scrollbar{width:3px;height:3px;}::-webkit-scrollbar-track{background:var(--black);}::-webkit-scrollbar-thumb{background:var(--border2);}
@media(max-width:700px){.kpi-strip{flex-wrap:wrap;}.kpi{min-width:calc(33% - 1px);}.table-wrap{padding:0 10px 60px;}}
</style>
</head>
